rules_version = '2';

// Firebase Storage security rules for EcoVibeFloors
// Product images are publicly readable, but uploads are restricted
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for product images
    // Authenticated admins (role === 'admin' in Firestore) can upload/delete
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public read access for author photos
    match /authors/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Block all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
